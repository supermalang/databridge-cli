# Production env for docker-compose.prod.yml. Copy to .env, fill in, keep secret.
#   cp .env.prod.example .env
# Compose uses this file both for ${VAR} interpolation and as the app's env_file.

# ── Public URL / TLS ──────────────────────────────────────────────────────────
# The domain Caddy serves (DNS A/AAAA record must point at this host).
APP_DOMAIN=app.example.com
# Public base URL — drives the OIDC redirect URI and (over https) secure cookies.
APP_BASE_URL=https://app.example.com

# ── Auth (Zitadel OIDC) ───────────────────────────────────────────────────────
# Register https://<APP_DOMAIN>/auth/callback as a redirect URI and
# https://<APP_DOMAIN>/ as a post-logout URI in your Zitadel app.
OIDC_ISSUER=https://your-instance.zitadel.cloud
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Long random string (e.g. `openssl rand -hex 32`). Encrypts the session cookie.
SESSION_SECRET=
# Comma-separated emails granted global superadmin on login.
SUPERADMIN_EMAILS=
# Optional — Zitadel service-user PAT so admins can invite new users from the app.
ZITADEL_API_TOKEN=

# ── Database (internal Postgres service) ──────────────────────────────────────
# The app's DATABASE_URL is built from this in docker-compose.prod.yml.
POSTGRES_PASSWORD=change-me-strong

# ── Object storage (internal Minio service) ───────────────────────────────────
# These also become Minio's root credentials and the bucket name.
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me-strong
S3_BUCKET=databridge
S3_REGION=us-east-1
# (S3_ENDPOINT_URL + STORAGE_BACKEND are set to the minio service in compose.)

# ── Data source + AI (as needed) ──────────────────────────────────────────────
KOBO_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Langfuse prompt management / tracing (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

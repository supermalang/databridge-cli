# Caddy reverse proxy with automatic HTTPS (Let's Encrypt) for APP_DOMAIN.
# {$APP_DOMAIN} is read from the environment (set in .env / compose).
#
#   APP_DOMAIN=app.example.com   → public HTTPS site, auto-certs
#   APP_DOMAIN=:80               → plain HTTP (local testing, no certs)
{$APP_DOMAIN} {
	encode zstd gzip

	reverse_proxy app:8000 {
		# Stream Server-Sent Events (the /api/run log streams) to the client
		# immediately instead of buffering — without this, run logs arrive only
		# when the command finishes.
		flush_interval -1
	}
}

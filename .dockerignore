# Keep the build context (and image) lean.
.git
.github
.devcontainer
.dev
node_modules
frontend/node_modules
frontend/dist
**/__pycache__
*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
tests
docs
references

# Local data / secrets / generated output — never bake into the image.
.env
.env.*
config.yml
data/raw
data/processed
reports
templates/*.docx
*.bak-crlf

# Editor / OS noise
.vscode
.idea
.DS_Store

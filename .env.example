# kobo-reporter · .env
# Copy to .env and fill in your values.

# ── Kobo / Ona ──────────────────────────────────────────────────────────────
KOBO_TOKEN=your_kobo_or_ona_api_token

# ── Domain (used by Traefik labels) ─────────────────────────────────────────
APP_DOMAIN=kobo-reporter.yourdomain.com

# ── Basic auth (optional — htpasswd format) ──────────────────────────────────
# Generate with: htpasswd -nb username password
# Or online: https://www.web2generators.com/apache-tools/htpasswd-generator
# Leave empty to disable auth (not recommended for public domains)
BASIC_AUTH_USERS=admin:$$apr1$$xyz...   # escape $ as $$ in .env

# ── Database export (optional) ───────────────────────────────────────────────
DB_USER=
DB_PASSWORD=
SUPABASE_KEY=
DOCKER_BUILDKIT=1
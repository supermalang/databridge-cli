KOBO_TOKEN=your_kobo_or_ona_api_token
APP_DOMAIN=kobo-reporter.yourdomain.com
# Auth — Zitadel OIDC login gate. Leave OIDC_* empty to run with auth DISABLED
# (local dev: every request resolves to a built-in dev user).
OIDC_ISSUER=                     # e.g. https://your-instance.zitadel.cloud
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
SESSION_SECRET=                  # any long random string; used to encrypt the session cookie
APP_BASE_URL=http://localhost:8000   # public base URL; drives the OIDC redirect URI
# Per-project RBAC. Comma-separated emails granted global superadmin on login
# (they can access every project + manage other superadmins).
SUPERADMIN_EMAILS=
# Optional — Zitadel Management API token (a service-user PAT) so admins can invite
# brand-new people from the app (creates the user in Zitadel + emails them). Leave
# empty to record app-level invites only (consumed when that email signs in).
ZITADEL_API_TOKEN=
# App database (Postgres). Required. Example local Postgres:
#   docker run --rm -e POSTGRES_PASSWORD=dev -e POSTGRES_DB=databridge -p 5432:5432 postgres:16
DATABASE_URL=postgresql+psycopg2://postgres:dev@localhost:5432/databridge
# Object storage (Minio/S3). Required. Example local Minio:
#   docker run --rm -p 9000:9000 -p 9001:9001 -e MINIO_ROOT_USER=minio \
#     -e MINIO_ROOT_PASSWORD=minio12345 minio/minio server /data --console-address ":9001"
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=databridge
S3_REGION=us-east-1
DB_USER=
DB_PASSWORD=
SUPABASE_KEY=
DOCKER_BUILDKIT=1
# AI narrative generation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Langfuse — prompt management + LLM tracing (https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Alias accepted by the client if LANGFUSE_HOST is unset (matches the SDK's `base_url`):
# LANGFUSE_BASE_URL=https://cloud.langfuse.com